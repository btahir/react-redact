{
	"name": "react-redact",
	"version": "0.1.0",
	"description": "One keyboard shortcut to make your entire app demo-safe",
	"license": "MIT",
	"type": "module",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			}
		},
		"./styles.css": "./dist/styles/redact.css"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"sideEffects": [
		"*.css"
	],
	"keywords": [
		"react",
		"redact",
		"pii",
		"privacy",
		"blur",
		"mask",
		"demo-mode",
		"screenshare",
		"sensitive-data",
		"gdpr"
	],
	"peerDependencies": {
		"react": ">=18.0.0",
		"react-dom": ">=18.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.0",
		"@changesets/cli": "^2.27.0",
		"@testing-library/jest-dom": "^6.0.0",
		"@testing-library/react": "^16.0.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"jsdom": "^25.0.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"tsup": "^8.5.1",
		"typescript": "^5.7.0",
		"vitest": "^3.0.0"
	},
	"scripts": {
		"build": "tsup && node -e \"require('fs').mkdirSync('dist/styles',{recursive:true}); require('fs').copyFileSync('src/styles/redact.css','dist/styles/redact.css')\"",
		"dev": "tsup --watch",
		"test": "vitest",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"check": "biome check .",
		"check:fix": "biome check --fix .",
		"prepublishOnly": "pnpm run build",
		"changeset": "changeset",
		"version": "changeset version",
		"release": "pnpm run build && changeset publish"
	}
}
